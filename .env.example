# ==============================================================================
# CRT Web Application — Environment Configuration
# Copy this file to `.env` and fill in real values before running
# `docker compose up`. See README.md for details on each phase of deployment.
# ==============================================================================

# --- Database -----------------------------------------------------------------
# Used by: api
# Default (docker compose): postgresql+psycopg://crt:crt@db:5432/crt
# SQLite fallback (sqlite:///./dev.db) is only used when this is UNSET and
# APP_ENV=development (local/no-Docker dev and unit tests only).
DATABASE_URL=postgresql+psycopg://crt:crt@db:5432/crt

# --- Security -------------------------------------------------------------------
# Used by: api
# REQUIRED. Must be >= 32 random bytes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-32-byte-or-longer-secret-value

# --- Application environment ---------------------------------------------------
# Used by: api
# "development" | "production"
# In production, cookies are marked Secure and require HTTPS (terminated by
# your tunnel/host).
APP_ENV=development

# --- Token lifetimes -------------------------------------------------------------
# Used by: api
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Seed admin account (FR-7) ----------------------------------------------------
# Used by: api
# REQUIRED on first boot. If no admin user exists, one is created from these
# values and a warning is logged prompting a password change.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now-please

# --- CORS -------------------------------------------------------------------------
# Used by: api
# Comma-separated list of allowed origins. Empty = same-origin only (the
# normal case, since the frontend calls the API via the relative /api/v1
# path proxied by nginx).
ALLOWED_ORIGINS=

# --- Web (frontend/nginx) container ------------------------------------------------
# Used by: docker compose
# Host port that the `web` service is published on.
WEB_PORT=8080

# --- Postgres container -------------------------------------------------------------
# Used by: db
# Change these in any shared/production deployment.
POSTGRES_USER=crt
POSTGRES_PASSWORD=crt
POSTGRES_DB=crt
